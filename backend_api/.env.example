# Required (choose one approach)
# Option A (preferred): single URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Option B: DB parts (used if DATABASE_URL is missing)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Optional
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO

RUNNER_WORKDIR=backend_api/runner-java
RUNNER_MVN_CMD=mvn
RUNNER_MAX_CONCURRENCY=1

# Optional (for Sauce Labs)
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
CORS_ALLOW_ORIGINS=*

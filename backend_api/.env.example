# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO

RUNNER_WORKDIR=backend_api/runner-java
RUNNER_MVN_CMD=mvn
RUNNER_MAX_CONCURRENCY=1

# Optional (for Sauce Labs)
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
CORS_ALLOW_ORIGINS=*
